/target
.idea
/test_data/
/crates/shamir-db/test_data/
# Match test_data anywhere in the workspace (each crate's tests
# materialise their own fixture dirs).
**/test_data/

# Claude Code session-local state (scheduled wakeups, etc.) — local
# to each developer's machine, never to be committed.
/.claude/

# Scratch directory for sub-agent task prompts (`tmp/impl-X.txt`),
# their result files (`tmp/impl-X.json`/`.err`), audit reports,
# any throwaway artefacts. Never committed.
/tmp/
# Legacy scratch pattern from before the `tmp/` convention.
.tmp-*
/web/server-cert.pem

# `**/` — match at any depth (covers web/, crates/shamir-client-node/,
# tests/e2e/, …). Single `*/node_modules/*` only matched 1-level paths.
**/node_modules/

# Node binding build artefacts
crates/shamir-client-node/package-lock.json
crates/shamir-client-node/*.node
tests/e2e/package-lock.json
examples/*/target/
examples/*/Cargo.lock

# local dev artifacts
server-cert.pem
crates/shamir-client-node/target/
crates/shamir-client-node/Cargo.lock
devrust.cargo-target-bench/
