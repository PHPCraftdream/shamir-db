{
  "name": "shamir-client",
  "version": "0.1.0",
  "description": "ShamirDB Node.js client SDK — TLS 1.3 + SCRAM-Argon2id, native binding to the Rust shamir-client crate.",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "shamir-client.*.node"
  ],
  "license": "MIT OR Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "napi": {
    "binaryName": "shamir-client",
    "targets": [
      "x86_64-pc-windows-gnu",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  }
}
