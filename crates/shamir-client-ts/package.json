{
  "name": "@shamir/client",
  "version": "0.1.0",
  "private": true,
  "description": "ShamirDB TypeScript client (WS + SCRAM-Argon2id + msgpack) — Node + Browser.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    }
  },
  "browser": {
    "./dist/index.js": "./dist/browser.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0",
    "@noble/ciphers": "^0.5.0",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.8.0",
    "argon2-browser": "^1.18.0",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@types/argon2-browser": "^1.18.4",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
