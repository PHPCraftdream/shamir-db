#!/usr/bin/env sh
#
# ShamirDB pre-push gate.
#
# Mirrors the CLAUDE.md pre-commit gate so a push can never land formatting
# drift, lint regressions, or failing library tests on a shared branch.
#
# Activate once per clone:
#     git config core.hooksPath .githooks
#
# Bypass (emergencies only — you own the consequences):
#     git push --no-verify
#   or
#     SHAMIR_SKIP_PREPUSH=1 git push
#
set -e

if [ "${SHAMIR_SKIP_PREPUSH:-0}" = "1" ]; then
    echo "pre-push: skipped (SHAMIR_SKIP_PREPUSH=1)"
    exit 0
fi

# Run from the repo root regardless of where git invoked us.
repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

echo "pre-push [1/3]: cargo fmt --all -- --check"
cargo fmt --all -- --check

echo "pre-push [2/3]: cargo clippy --workspace --all-targets -- -D warnings"
cargo clippy --workspace --all-targets -- -D warnings

echo "pre-push [3/3]: cargo test --workspace --lib"
cargo test --workspace --lib

echo "pre-push: all checks passed — pushing."

cargo sweep --time 7 2>/dev/null || true
