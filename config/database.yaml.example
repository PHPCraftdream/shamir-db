# SHAMIR Database Configuration

# Base directory for all repository data
data_dir: "./data"

# Repositories map (repo name -> config)
repos:
  # Default repository
  main:
    # Storage engine: Canopy, Fjall, Cached, Memory, Nebari, Persy, Redb, Sled
    storage_type: Redb
    # Enable RAM caching for tables # occupies the full volume in RAM
    ram_cached: false

    # Tables configuration
    tables:
      users:
        # Regular indexes (optional)
        indexes:
          email_idx:
            # Path to the field (string for single field, multiple strings for composite)
            # Empty array [] means index full value
            paths:
              - email
          name_idx:
            paths:
              - name

        # Unique indexes (optional)
        indexes_unique:
          user_id_idx:
            paths:
              - id

      products:
        indexes:
          # Composite index on category and subcategory
          category_subcategory_idx:
            paths:
              - category
              - subcategory
        indexes_unique:
          sku_idx:
            paths:
              - sku

      orders:
        indexes:
          # Nested field index using dot notation
          # Indexes email field inside user object
          user_email_idx:
            paths:
              - user.email
          # Composite index with nested and flat fields
          user_date_idx:
            paths:
              - user.email
              - order_date
        # indexes_unique is optional and can be omitted

      logs:
        # Table with no indexes at all
        # indexes and indexes_unique can both be omitted

  # Secondary repository
  analytics:
    storage_type: Fjall
    ram_cached: false
    tables:
      events:
        indexes:
          timestamp_idx:
            paths:
              - timestamp
          type_idx:
            paths:
              - event_type
        indexes_unique: {}
